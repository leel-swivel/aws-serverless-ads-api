			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"let response = pm.response.json();",
							"if (response.AuthenticationResult && response.AuthenticationResult.IdToken) {",
							"    let token = response.AuthenticationResult.IdToken;",
							"    pm.environment.set(\"ID_TOKEN\", token);",
							"    console.log(\"ID_TOKEN saved successfully\");",
							"} else {",
							"    console.log(\"Login failed - No IdToken found\");",
							"}"
						],
						"type": "text/javascript",
